    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "description": "Large indexes that are rarely or never used - prime candidates for removal",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10485760 },
              { "color": "orange", "value": 104857600 },
              { "color": "red", "value": 524288000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "index_name" },
            "properties": [{ "id": "custom.width", "value": 400 }]
          },
          {
            "matcher": { "id": "byName", "options": "index_size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "scans" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 10 }, { "color": "green", "value": 100 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "index_size" }]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  schemaname || '.' || indexrelname AS index_name,\n  schemaname || '.' || relname AS table_name,\n  pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass) AS index_size,\n  idx_scan AS scans,\n  idx_tup_read AS tuples_read,\n  idx_tup_fetch AS tuples_fetched,\n  CASE WHEN idx_scan > 0 THEN 'Used' ELSE 'UNUSED' END AS status\nFROM pg_stat_user_indexes\nWHERE pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass) > 65536\nORDER BY \n  CASE WHEN idx_scan = 0 THEN 0 ELSE 1 END,\n  pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass) DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Biggest Indexes (Prioritized by Low Usage)",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "description": "Indexes sorted by size-to-usage ratio - larger ratio means less efficient",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "index_name" },
            "properties": [{ "id": "custom.width", "value": 350 }]
          },
          {
            "matcher": { "id": "byName", "options": "index_size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "bytes_per_scan" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1048576 }, { "color": "red", "value": 104857600 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 13 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "bytes_per_scan" }]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  schemaname || '.' || indexrelname AS index_name,\n  pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass) AS index_size,\n  idx_scan AS scans,\n  CASE WHEN idx_scan > 0 \n    THEN pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass) / idx_scan \n    ELSE pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass)\n  END AS bytes_per_scan\nFROM pg_stat_user_indexes\nWHERE pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(indexrelname))::regclass) > 65536\nORDER BY bytes_per_scan DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Least Efficient Indexes (Bytes per Scan)",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "description": "Duplicate or redundant indexes on the same columns",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "index_size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 13 },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  pg_size_pretty(sum(pg_relation_size(idx))::bigint) AS total_size,\n  (array_agg(idx))[1] AS index_name,\n  count(*) AS index_count,\n  max(indexdef) AS definition\nFROM (\n  SELECT \n    indexrelid::regclass AS idx, \n    (indrelid::text || E'\\n' || indclass::text || E'\\n' || indkey::text || E'\\n' || coalesce(indexprs::text,'') || E'\\n' || coalesce(indpred::text,'')) AS key,\n    pg_get_indexdef(indexrelid) AS indexdef\n  FROM pg_index\n  WHERE indrelid::regclass::text NOT LIKE 'pg_%'\n) sub\nGROUP BY key\nHAVING count(*) > 1\nORDER BY sum(pg_relation_size(idx)) DESC\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Potentially Duplicate Indexes",
      "type": "table"
    },
