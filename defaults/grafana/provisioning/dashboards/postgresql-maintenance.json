        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "dead_ratio_pct" }]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  schemaname || '.' || relname AS table_name,\n  pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(relname))::regclass) AS table_size,\n  n_live_tup AS live_tuples,\n  n_dead_tup AS dead_tuples,\n  CASE WHEN n_live_tup > 0 \n    THEN round(100.0 * n_dead_tup / n_live_tup, 2) \n    ELSE 0 \n  END AS dead_ratio_pct,\n  last_vacuum,\n  last_autovacuum,\n  last_analyze\nFROM pg_stat_user_tables\nWHERE n_dead_tup > 0 OR n_live_tup > 1000\nORDER BY \n  CASE WHEN n_live_tup > 0 THEN n_dead_tup::float / n_live_tup ELSE 0 END DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Tables Needing VACUUM (by Dead Tuple Ratio)",
      "type": "table"
    },
