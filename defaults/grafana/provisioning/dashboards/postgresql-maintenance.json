          "rawSql": "SELECT \n  schemaname || '.' || relname AS table_name,\n  pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(relname))::regclass) AS table_size,\n  n_live_tup AS rows,\n  last_analyze,\n  last_autoanalyze,\n  COALESCE(last_analyze, last_autoanalyze, '1970-01-01'::timestamp) AS last_stats_update\nFROM pg_stat_user_tables\nWHERE n_live_tup > 100\nORDER BY COALESCE(last_analyze, last_autoanalyze, '1970-01-01'::timestamp) ASC\nLIMIT 20",
          "refId": "A"
