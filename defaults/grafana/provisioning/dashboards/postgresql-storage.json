          "rawQuery": true,
          "rawSql": "SELECT \n  schemaname || '.' || relname AS table_name,\n  pg_total_relation_size((quote_ident(schemaname) || '.' || quote_ident(relname))::regclass) AS total_size,\n  pg_relation_size((quote_ident(schemaname) || '.' || quote_ident(relname))::regclass) AS table_size,\n  pg_indexes_size((quote_ident(schemaname) || '.' || quote_ident(relname))::regclass) AS index_size\nFROM pg_stat_user_tables\nORDER BY pg_total_relation_size((quote_ident(schemaname) || '.' || quote_ident(relname))::regclass) DESC\nLIMIT 20",
