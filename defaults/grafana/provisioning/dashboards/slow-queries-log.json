  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Slow queries (>1000ms) extracted from dbserver logs. Source: log_min_duration_statement. Time-window via UI picker; Loki keeps dbserver logs for 90 days.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.width", "value": 120 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2000 }, { "color": "orange", "value": 5000 }, { "color": "red", "value": 10000 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "duration_ms" }]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{service=\"dbserver\"} |~ \"duration: [0-9]+\\\\.[0-9]+ ms\" | regexp `duration: (?P<duration_ms>[0-9.]+) ms\\s+(?:statement|execute [^:]+): (?P<query>.*)$` | duration_ms > 1000",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Slow queries (>1000ms)",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "id": true,
              "labels": true,
              "tsNs": true,
              "service": true
            },
            "indexByName": {
              "Time": 0,
              "duration_ms": 1,
              "query": 2
            },
            "renameByName": {}
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["postgresql", "bpp"],
